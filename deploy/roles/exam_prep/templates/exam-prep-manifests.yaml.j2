---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: exam-prep
  namespace: {{ demo_namespace }}
  labels:
    app: exam-prep
spec:
  replicas: 1
  selector:
    matchLabels:
      app: exam-prep
  template:
    metadata:
      labels:
        app: exam-prep
    spec:
      containers:
        - name: exam-prep
          image: {{ exam_prep_image }}
          imagePullPolicy: Never
          ports:
            - containerPort: 80
              name: http
          resources:
            requests:
              memory: "64Mi"
              cpu: "50m"
            limits:
              memory: "128Mi"
              cpu: "200m"

---
apiVersion: v1
kind: Service
metadata:
  name: exam-prep
  namespace: {{ demo_namespace }}
  labels:
    app: exam-prep
spec:
  type: ClusterIP
  ports:
    - port: 80
      targetPort: 80
      name: http
  selector:
    app: exam-prep

---
# Ingress séparé pour /prep-exam.
# Pas de bloc tls: ici — le TLS pour cnpglab.freeddns.org est géré
# exclusivement par l'ingress "frontend" (cert-manager + frontend-tls).
# Définir tls: dans deux ingresses pour le même host provoque un conflit
# dans nginx-ingress et casse la présentation du certificat.
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: exam-prep
  namespace: {{ demo_namespace }}
spec:
  ingressClassName: nginx
  rules:
  - host: {{ ingress_domain }}
    http:
      paths:
      - path: /prep-exam
        pathType: Prefix
        backend:
          service:
            name: exam-prep
            port:
              number: 80
